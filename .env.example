# Скопируй в .env и заполни значения. Секреты не коммитить (см. SECURITY.md).

# --- Обязательно для бота и Telethon ---
BOT_TOKEN=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# --- SQLite ---
DATABASE_PATH=./data/bot.db

# Telethon: файл префикса сессии или строка сессии (для PaaS удобнее строка)
TELETHON_SESSION=./data/telethon_session
# TELETHON_SESSION_STRING=

# --- X / Twitter источники (если ENABLE_X_SOURCES=0, токен можно оставить пустым) ---
ENABLE_X_SOURCES=1
X_API_BEARER_TOKEN=
X_API_BASE_URL=https://api.x.com/2
X_API_FETCH_INTERVAL_SECONDS=60
X_API_SOURCES_PER_TICK=1
X_API_USER_CACHE_TTL_SECONDS=86400
X_API_MAX_PAGES_PER_SOURCE=1
X_API_MAX_RESULTS=20
X_API_MAX_REQUESTS_PER_HOUR=120
X_FETCH_TIMEOUT_SECONDS=25

# --- Циклы ---
COLLECTOR_POLL_SECONDS=3
DIGEST_POLL_SECONDS=60
LOG_LEVEL=INFO

# --- Медиа ---
ENABLE_MEDIA_DOWNLOADS=1
MIN_FREE_DISK_MB=512
MEDIA_RETENTION_DAYS=3

# --- Автопостинг в Telegram-канал (MVP, отдельный контур) ---
ENABLE_CHANNEL_AUTOPUBLISH=0
# ID канала вида -100...
CHANNEL_CHAT_ID=
CHANNEL_MAX_POSTS_PER_DAY=20
CHANNEL_POLL_SECONDS=30
CHANNEL_MIN_CANDIDATE_CHARS=24
CHANNEL_NEAR_DUP_JACCARD=0.82
# Сколько постов за один тик опроса отдавать в LLM (меньше — мягче для лимита TPM Groq)
CHANNEL_LLM_CANDIDATES_PER_TICK=2
# Пауза между двумя постами в одном тике, сек (снижает всплеск запросов к Groq)
CHANNEL_LLM_GAP_SECONDS=15
# Размер окна сравнения для pre/post-LLM дедупа (последние N опубликованных)
CHANNEL_DEDUP_LOOKBACK_LIMIT=600
# Режим отправки видео в канал:
# - video_preview: обычный видеоплеер Telegram с превью в ленте (рекомендуется)
# - document: файл без сжатия, но без обычного видео-превью в ленте
CHANNEL_VIDEO_SEND_MODE=video_preview
# Backward compatibility (устаревшее): если CHANNEL_VIDEO_SEND_MODE не задан,
# CHANNEL_VIDEO_NO_COMPRESSION=1 => document, иначе => video_preview
# CHANNEL_VIDEO_NO_COMPRESSION=0
# Источники (username через запятую) для watermark-safe режима: в канал уходит text-only без медиа
# Пример: CHANNEL_TEXT_ONLY_SOURCES=opensource_hub,another_channel
CHANNEL_TEXT_ONLY_SOURCES=

LLM_PROVIDER=sambanova
# Новый режим: primary/fallback роутер провайдеров
LLM_PRIMARY_PROVIDER=sambanova
LLM_FALLBACK_ENABLED=1
LLM_FALLBACK_PROVIDER=groq

SAMBANOVA_API_KEY=
SAMBANOVA_MODEL=Meta-Llama-3.1-8B-Instruct
SAMBANOVA_API_BASE=https://api.sambanova.ai/v1

GROQ_API_KEY=
# Groq-модель для fallback
LLM_MODEL=llama-3.1-8b-instant
LLM_TIMEOUT_SECONDS=25
# При 429 Groq ждет время из ответа; больше попыток = терпеливее к TPM
LLM_MAX_RETRIES=4
LLM_MAX_INPUT_CHARS=4500
LLM_MAX_OUTPUT_TOKENS=450
